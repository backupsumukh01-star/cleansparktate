# Required
SITE_PASSWORD=your_secret_password
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Server
PORT=3001
NODE_ENV=production

# Set to true only when using HTTPS (production behind SSL)
COOKIE_SECURE=false

# Optional: set if frontend is on a different origin
# CLIENT_ORIGIN=https://your-domain.com

# Telegram — one bot per person (recommended for 2 users)
# User 1 gets notified when User 2 messages while User 1 is offline
TELEGRAM_BOT_TOKEN_USER1=
TELEGRAM_CHAT_ID_USER1=

# User 2 gets notified when User 1 messages while User 2 is offline
TELEGRAM_BOT_TOKEN_USER2=
TELEGRAM_CHAT_ID_USER2=

# Optional fallback: same bot/chat for both (not recommended)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
